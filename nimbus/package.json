{
  "name": "nimbus",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android --active-arch-only --no-packager",
    "ios": "react-native run-ios --no-packager",
    "android:with-packager": "react-native run-android --active-arch-only",
    "ios:with-packager": "react-native run-ios",
    "dev": "bash ../scripts/open-services-in-terminal.sh --android",
    "dev:android": "bash ../scripts/open-services-in-terminal.sh --android",
    "dev:ios": "bash ../scripts/open-services-in-terminal.sh --ios",
    "dev:all": "bash ../scripts/open-services-in-terminal.sh --android --ios",
    "lint": "eslint .",
    "postinstall": "patch-package",
    "start": "bash scripts/free-metro-port.sh && react-native start",
    "start:fast": "bash scripts/free-metro-port.sh && react-native start --reset-cache",
    "test": "jest"
  },
  "dependencies": {
    "@expo/vector-icons": "^14.1.0",
