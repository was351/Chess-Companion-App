    "@react-navigation/native": "^7.1.9",
    "@react-navigation/native-stack": "^7.3.10",
    "@tamagui/animations-css": "^1.126.1",
    "@tamagui/animations-moti": "^1.126.1",
    "@tamagui/animations-react-native": "^1.126.1",
    "@tamagui/colors": "^1.126.1",
