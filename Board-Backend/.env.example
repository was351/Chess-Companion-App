# Supabase (required for backend)
SUPABASE_URL=https://your-project-ref.supabase.co
# Use service_role so the API can read/write users and insert completed_games without RLS issues.
SUPABASE_KEY=your_supabase_service_role_key

# JWT
SECRET_KEY=your_jwt_secret_min_32_chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Google Sign-In — OAuth 2.0 "Web application" client ID (must match GOOGLE_WEB_CLIENT_ID in nimbus .env)
GOOGLE_CLIENT_ID=your_web_client_id.apps.googleusercontent.com

# Lichess OAuth (optional)
LICHESS_CLIENT_ID=your_lichess_client_id
LICHESS_REDIRECT_URI=http://localhost:8000/auth/lichess/callback

# Friend chess (Redis) — required for POST /games, /games/join, etc.
#
# Host-run API + Redis on EC2 (apt/brew or Docker with 127.0.0.1:6379 published):
#   REDIS_URL=redis://127.0.0.1:6379/0
# API + Redis both via docker-compose.yml in this folder (default in compose):
#   REDIS_URL=redis://redis:6379/0
REDIS_URL=redis://127.0.0.1:6379/0
