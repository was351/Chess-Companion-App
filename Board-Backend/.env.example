# Supabase (required for backend)
SUPABASE_URL=https://your-project-ref.supabase.co
# Use service_role so the API can read/write users and insert completed_games without RLS issues.
SUPABASE_KEY=your_supabase_service_role_key

# JWT
SECRET_KEY=your_jwt_secret_min_32_chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Google Sign-In — OAuth 2.0 "Web application" client ID (must match GOOGLE_WEB_CLIENT_ID in nimbus .env)
GOOGLE_CLIENT_ID=your_web_client_id.apps.googleusercontent.com

# Lichess OAuth (optional)
LICHESS_CLIENT_ID=your_lichess_client_id
LICHESS_REDIRECT_URI=http://localhost:8000/auth/lichess/callback

# Friend chess (Redis) — required for POST /games, /games/join, etc.
#
# Host-run API + Redis on EC2 (apt/brew or Docker with 127.0.0.1:6379 published):
#   REDIS_URL=redis://127.0.0.1:6379/0
# API + Redis both via docker-compose.yml in this folder (default in compose):
#   REDIS_URL=redis://redis:6379/0
REDIS_URL=redis://127.0.0.1:6379/0

# Abandoned friend games: background sweep interval (seconds). Inserts `completed_games` with
# result=abandoned when Redis live keys TTL out (needs nullable black_player_id in Supabase — README).
ABANDONED_GAME_SWEEP_SEC=300

# Stockfish engine jobs (Redis db 1 by default — separate from friend games on db 0)
# Host-run API + Redis:
#   REDIS_ENGINE_URL=redis://127.0.0.1:6379/1
# Docker stack (same redis service, different logical DB):
#   REDIS_ENGINE_URL=redis://redis:6379/1
REDIS_ENGINE_URL=redis://127.0.0.1:6379/1

# Engine queue tuning (optional — defaults in engine/config.py)
# ENGINE_VISIBILITY_TIMEOUT_SEC=120
# ENGINE_MAX_ATTEMPTS=3
# ENGINE_MAX_DEPTH=30

# Stockfish worker (engine-worker container only — not used by API process)
# STOCKFISH_PATH=/usr/games/stockfish
# STOCKFISH_HASH_MB=64
# STOCKFISH_THREADS=1
